{
  "name": "@semiont/cli",
  "version": "0.5.11",
  "description": "Semiont CLI - Unified environment management tool",
  "_comment": "AWS SDK dependencies (@aws-sdk/*) are only used by platforms/aws",
  "type": "module",
  "bin": {
    "semiont": "./dist/cli.mjs"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/The-AI-Alliance/semiont.git",
    "directory": "apps/cli"
  },
  "keywords": [
    "semiont",
    "cli",
    "environment-management",
    "devops",
    "deployment",
    "infrastructure"
  ],
  "author": "Semiont Team",
  "license": "Apache-2.0",
  "scripts": {
    "build": "node build.mjs && npm run typecheck",
    "build:only": "node build.mjs",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest",
    "test:run": "vitest run",
    "test:unit": "vitest run --config vitest.config.unit.ts",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "test:all": "npm run test:unit && npm run test:integration",
    "test:watch": "vitest --watch",
    "test:watch:unit": "vitest --watch --config vitest.config.unit.ts"
  },
  "dependencies": {
    "@semiont/content": "*",
    "@semiont/core": "*",
    "@semiont/event-sourcing": "*",
    "@semiont/graph": "*",
    "@semiont/http-transport": "*",
    "@semiont/make-meaning": "*",
    "@semiont/sdk": "*",
    "arg": "^5.0.2",
    "argon2": "^0.44.0",
    "express": "^5.2.1",
    "ink": "^7.0.5",
    "js-yaml": "^4.2.0",
    "neo4j-driver": "^6.1.0",
    "react": "^19.2.6",
    "smol-toml": "^1.7.0",
    "socket.io": "^4.5.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@prisma/client": "^7.8.0",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^19.2.16",
    "@vitest/coverage-v8": "^4.1.8",
    "chalk": "^5.3.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.8"
  },
  "optionalDependencies": {
    "@aws-sdk/client-cloudformation": "^3.1075.0",
    "@aws-sdk/client-cloudwatch": "^3.1075.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1075.0",
    "@aws-sdk/client-cost-explorer": "^3.1075.0",
    "@aws-sdk/client-ecr": "^3.1075.0",
    "@aws-sdk/client-ecs": "^3.1075.0",
    "@aws-sdk/client-efs": "^3.1075.0",
    "@aws-sdk/client-elastic-load-balancing-v2": "^3.1075.0",
    "@aws-sdk/client-lambda": "^3.1075.0",
    "@aws-sdk/client-neptune": "^3.1075.0",
    "@aws-sdk/client-rds": "^3.1075.0",
    "@aws-sdk/client-route-53": "^3.1075.0",
    "@aws-sdk/client-secrets-manager": "^3.1075.0",
    "@aws-sdk/client-sts": "^3.1075.0",
    "@aws-sdk/client-wafv2": "^3.1075.0"
  },
  "overrides": {
    "esbuild": "0.27.2"
  }
}

{
  "name": "@semiont/graph",
  "version": "0.5.11",
  "engines": {
    "node": ">=24.0.0"
  },
  "type": "module",
  "description": "Graph database abstraction with Neo4j, Neptune, JanusGraph, and in-memory implementations",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "npm run typecheck && tsup && tsc -p tsconfig.build.json && rollup -c rollup.dts.config.mjs && rm -rf dist-types",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist dist-types",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@semiont/core": "*",
    "@semiont/http-transport": "*",
    "@semiont/ontology": "*",
    "uuid": "^14.0.0"
  },
  "peerDependencies": {
    "gremlin": "^3.7.4",
    "neo4j-driver": "^6.1.0"
  },
  "peerDependenciesMeta": {
    "neo4j-driver": {
      "optional": true
    },
    "gremlin": {
      "optional": true
    },
    "@aws-sdk/client-neptune": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/gremlin": "^3.6.7",
    "@vitest/coverage-v8": "^4.1.8",
    "rollup": "^4.61.0",
    "rollup-plugin-dts": "^6.4.1",
    "tsup": "^8.0.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "graph-database",
    "neo4j",
    "neptune",
    "janusgraph",
    "gremlin",
    "knowledge-graph",
    "semantic-web"
  ],
  "author": "The AI Alliance",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/The-AI-Alliance/semiont.git",
    "directory": "packages/graph"
  },
  "optionalDependencies": {
    "@aws-sdk/client-neptune": "^3.1075.0"
  }
}

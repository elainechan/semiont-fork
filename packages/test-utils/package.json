{
  "name": "@semiont/test-utils",
  "version": "0.5.11",
  "engines": {
    "node": ">=24.0.0"
  },
  "description": "Shared test utilities and mock factories for Semiont",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.8",
    "typescript": "^6.0.2",
    "vitest": "^4.1.8"
  }
}

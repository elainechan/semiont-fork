{
  "name": "@semiont/jobs",
  "version": "0.5.11",
  "engines": {
    "node": ">=24.0.0"
  },
  "type": "module",
  "description": "Filesystem-based job queue and worker infrastructure",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./worker-main": {
      "types": "./dist/worker-main.d.ts",
      "import": "./dist/worker-main.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "npm run typecheck && tsup && tsc -p tsconfig.build.json && rollup -c rollup.dts.config.mjs && rm -rf dist-types",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@semiont/http-transport": "*",
    "@semiont/content": "*",
    "@semiont/core": "*",
    "@semiont/event-sourcing": "*",
    "@semiont/inference": "*",
    "@semiont/observability": "*",
    "@semiont/sdk": "*"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.8",
    "rollup": "^4.61.0",
    "rollup-plugin-dts": "^6.4.1",
    "tsup": "^8.0.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "job-queue",
    "worker",
    "task-queue",
    "filesystem",
    "background-jobs"
  ],
  "author": "The AI Alliance",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/The-AI-Alliance/semiont.git",
    "directory": "packages/jobs"
  }
}
